  4: "Проверка полноты (циклично дополнять)"
}

# Scope
scope = {
  "общий": "широкое применение",
  "специальный": "конкретные субъекты/ситуации"
}

# case_note структура (3 блока)
case_note_template = """
1. УСЛОВИЯ: [субъекты, факты, доказательства]
2. ПРИМЕНЯЕТСЯ/МОЖЕТ ЕСЛИ: [категоричность с обоснованием]
3. МЕХАНИЗМ: [как заявить, доказательства, связь с нормами]
"""

# JSON схема (строго)
output_schema = {
  "Norms": [
    {
      "act": "string",        // ГК РФ, КоАП РФ
      "date": "ДД.ММ.ГГГГ",  // 30.11.1994
      "number": "string",     // 230-ФЗ
      "art": "string",        // 333
      "art_title": "string|null",
      "art_part": "string|''", // ч.1, п.2
      "scope": "общий|специальный",
      "gen_note": "string",   // суть + релевантность
      "case_note": "string"   // 3 блока по шаблону
    }
  ],
  "Conclusion": {
    "synthesis": "string",  // анализ по блокам
    "answer": "string"      // ответ + алгоритм с ссылками (ст.XXX ГК РФ)
  }
}

# Quality Gates (перед JSON)
gates = [
  "1. Полнота по запросу?",
  "2. Защиты для санкций?",
  "3. Процедуры при спорах?",
