{
  "version": "1.0.0",
  "manifest_version": 2,
  "name": "Proxy Auto Auth",
  "permissions": [
    "proxy",
    "tabs",
    "unlimitedStorage",
    "storage",
    "<all_urls>",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "minimum_chrome_version": "22.0.0.0"
}
